# =============================================================================
# Maya Sanghavi Jewels - WhatsApp Birthday/Anniversary Automation
# Copy this file to .env.local and fill in the secret values.
# Secrets must NEVER be committed. .env.local is gitignored.
# In Railway, set every variable in the service Variables panel.
# =============================================================================

# -----------------------------------------------------------------------------
# Meta WhatsApp Cloud API
# -----------------------------------------------------------------------------
# Non-secret identifiers (safe defaults for this brand, can stay committed):
WA_PHONE_NUMBER_ID=479129835283946
WA_WABA_ID=488367757690178
WA_APP_ID=1016104521118501

# SECRET: long-lived system user access token (Graph API). Set in .env.local / Railway.
WA_TOKEN=REPLACE_WITH_META_SYSTEM_USER_TOKEN

# -----------------------------------------------------------------------------
# Zoho CRM API v8 (US data center)
# -----------------------------------------------------------------------------
# Non-secret OAuth client id (safe default):
ZOHO_CLIENT_ID=1000.22O4TPG5UST4YRMV59WPQZ3IJX4JJW

# SECRET: Zoho OAuth client secret. Set in .env.local / Railway.
ZOHO_CLIENT_SECRET=REPLACE_WITH_ZOHO_CLIENT_SECRET

# SECRET: Zoho OAuth refresh token (offline access). Set in .env.local / Railway.
ZOHO_REFRESH_TOKEN=REPLACE_WITH_ZOHO_REFRESH_TOKEN

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
# SECRET: Postgres connection string. From Railway Postgres plugin.
# Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=REPLACE_WITH_POSTGRES_CONNECTION_STRING

# -----------------------------------------------------------------------------
# App / API auth
# -----------------------------------------------------------------------------
# SECRET: bearer token guarding every /api/* control endpoint.
# Generate a long random string, e.g. `openssl rand -hex 32`.
ADMIN_TOKEN=REPLACE_WITH_LONG_RANDOM_STRING

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# Timezone the daily cron run is scheduled and reported in.
RUN_TIMEZONE=Asia/Kolkata
